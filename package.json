		"svelte-check": "^4.4.3",
		"tailwindcss": "^4.2.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.0",
		"vite": "^7.3.1",
		"vitest": "^3.2.4",
		"vitest-browser-svelte": "^1.1.0"
	},
