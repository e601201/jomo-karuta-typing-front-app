		"svelte-check": "^4.4.8",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.0",
		"vite": "^8.0.14",
		"vitest": "^4.1.7",
		"vitest-browser-svelte": "^2.1.1"
	},
